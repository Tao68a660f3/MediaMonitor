<Window x:Class="MediaMonitor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="媒体同步调试终端 V2.5" Height="850" Width="520" Background="#F0F0F0">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="媒体源:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
            <ComboBox x:Name="ComboSessions" DisplayMemberPath="SourceAppUserModelId" SelectionChanged="ComboSessions_SelectionChanged"/>
        </DockPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="15" Margin="0,0,0,10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="5" Color="#DDDDDD" ShadowDepth="1" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="TxtTitle" Text="未检测到播放" FontSize="20" FontWeight="Bold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="TxtArtist" Text="未知艺术家" FontSize="14" Foreground="Gray" Margin="0,5"/>
                <TextBlock x:Name="TxtAlbum" Text="未知专辑" FontSize="12" Foreground="LightGray"/>

                <ProgressBar x:Name="PbProgress" Height="10" Margin="0,15,0,5" Foreground="#0078D7" Background="#E0E0E0" BorderThickness="0"/>
                <DockPanel>
                    <TextBlock x:Name="TxtTime" Text="00:00 / 00:00" FontSize="11" Foreground="Gray"/>
                    <TextBlock x:Name="TxtLrcStatus" Text="等待加载歌词..." FontSize="11" Foreground="DarkOrange" HorizontalAlignment="Right"/>
                </DockPanel>

                <TextBlock x:Name="TxtLyricDisplay" Text="(当前歌词预览)" Margin="0,15,0,0" HorizontalAlignment="Center" FontSize="16" FontWeight="Medium" Foreground="#333333" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2">
            <Expander Header="硬件与路径设置" IsExpanded="True" Background="Transparent">
                <Border Background="#E8E8E8" Padding="10" CornerRadius="5" Margin="0,5">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="传输方式:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                            <RadioButton x:Name="RbSerial" Content="串口模式" IsChecked="True" GroupName="TransMode" Margin="0,0,10,0" Click="TransMode_Changed"/>
                            <RadioButton x:Name="RbUdp" Content="UDP网络" GroupName="TransMode" Click="TransMode_Changed"/>
                        </StackPanel>

                        <Grid x:Name="GridSerialConfig" Margin="0,0,0,10" Visibility="Visible">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="2">
                                <TextBlock Text="串口号:" FontSize="10" Foreground="Gray"/>
                                <ComboBox x:Name="ComboPorts" SelectionChanged="ComboConfig_SelectionChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="2">
                                <TextBlock Text="波特率:" FontSize="10" Foreground="Gray"/>
                                <ComboBox x:Name="ComboBaud" SelectionChanged="ComboConfig_SelectionChanged" IsEditable="True">
                                    <ComboBoxItem Content="115200" IsSelected="True"/>
                                    <ComboBoxItem Content="9600"/>
                                    <ComboBoxItem Content="921600"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="GridUdpConfig" Margin="0,0,0,10" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="2">
                                <TextBlock Text="远程 IP 地址:" FontSize="10" Foreground="Gray"/>
                                <TextBox x:Name="TxtRemoteIp" Text="192.168.1.100" LostFocus="TxtRemoteIp_LostFocus" VerticalContentAlignment="Center" Height="22"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="2">
                                <TextBlock Text="远程端口:" FontSize="10" Foreground="Gray"/>
                                <TextBox x:Name="TxtRemotePort" Text="8080" PreviewTextInput="OnlyNumber_PreviewTextInput" DataObject.Pasting="NumberTextBox_Pasting" LostFocus="NumberTextBox_LostFocus" VerticalContentAlignment="Center" Height="22"/>
                            </StackPanel>
                        </Grid>

                        <DockPanel Margin="2,0,2,10">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="数据编码:" FontSize="10" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <ComboBox x:Name="ComboEncoding" SelectionChanged="ComboConfig_SelectionChanged" Width="100" VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="UTF-8" IsSelected="True"/>
                                    <ComboBoxItem Content="GB2312"/>
                                </ComboBox>
                            </StackPanel>

                            <Button x:Name="BtnSyncTime" Content="同步系统时间 (0x20)" Click="BtnSyncTime_Click" 
                                HorizontalAlignment="Right" Width="130" Height="24"
                                Background="#0078D7" Foreground="White" BorderThickness="0" Cursor="Hand">
                            </Button>
                        </DockPanel>

                        <StackPanel Margin="2,5,2,10">
                            <TextBlock Text="歌词搜索目录:" FontSize="10" Foreground="Gray"/>
                            <DockPanel>
                                <Button x:Name="BtnBrowse" Content="浏览..." DockPanel.Dock="Right" Width="60" Margin="5,0,0,0" Click="BtnBrowse_Click"/>
                                <TextBox x:Name="TxtLrcPath" Text="C:\Lyrics" IsReadOnly="True" VerticalContentAlignment="Center" Height="22"/>
                            </DockPanel>
                        </StackPanel>
                        
                        <WrapPanel Margin="0,8">
                            <CheckBox x:Name="ChkAdvancedMode" Content="高级协议(0xAA)" Click="CheckBox_Click" IsChecked="True" Margin="0,0,10,0"/>
                            <CheckBox x:Name="ChkIncremental" Content="增量差分" Click="CheckBox_Click" IsChecked="True" Margin="0,0,10,0"/>
                            <CheckBox x:Name="ChkTransOccupies" Content="翻译占行" Click="CheckBox_Click" IsChecked="True"/>
                            
                        </WrapPanel>

                        <UniformGrid Columns="3" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="缓冲区行数:" VerticalAlignment="Center" Width="65"/>
                                <TextBox x:Name="TxtLineLimit" Text="2" Width="40" PreviewTextInput="OnlyNumber_PreviewTextInput" DataObject.Pasting="NumberTextBox_Pasting" LostFocus="NumberTextBox_LostFocus"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="歌词偏移:" VerticalAlignment="Center" Width="65"/>
                                <TextBox x:Name="TxtOffset" Text="0" Width="40" PreviewTextInput="OnlyNumber_PreviewTextInput" DataObject.Pasting="NumberTextBox_Pasting" LostFocus="NumberTextBox_LostFocus"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="同步包间隔:" VerticalAlignment="Center" Width="65"/>
                                <TextBox x:Name="TxtSyncInterval" Text="500" Width="40" PreviewTextInput="OnlyNumber_PreviewTextInput" DataObject.Pasting="NumberTextBox_Pasting" LostFocus="NumberTextBox_LostFocus"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2" Visibility="Collapsed">
                                <TextBlock Text="逻辑帧(ms):" VerticalAlignment="Center" Width="65"/>
                                <TextBox x:Name="TxtUpdateRate" Text="50" Width="40" PreviewTextInput="OnlyNumber_PreviewTextInput" DataObject.Pasting="NumberTextBox_Pasting" LostFocus="NumberTextBox_LostFocus"/>
                            </StackPanel>
                        </UniformGrid>

                        <Button x:Name="BtnConnect" Content="开始连接" Click="BtnConnect_Click" Height="35" Background="#0078D7" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Expander>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="真·串口协议解析流 (TX):" FontWeight="Bold" Margin="0,10,0,5" Foreground="#444444"/>

        <RichTextBox Grid.Row="4" x:Name="HexPreview" Background="#1E1E1E" Foreground="#CCCCCC" FontFamily="Consolas" IsReadOnly="True" VerticalScrollBarVisibility="Auto">
            <FlowDocument>
                <Paragraph>
                    <Run Text="等待串口数据发送..." Foreground="#555555"/>
                </Paragraph>
            </FlowDocument>
        </RichTextBox>
    </Grid>
</Window>